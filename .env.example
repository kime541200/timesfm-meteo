DATABASE_URL=postgresql://<user>:<password>@localhost:5432/<dbname>

# Optional: where to store downloaded HuggingFace models (TimesFM checkpoint, etc.).
# Leave empty to use HF default (~/.cache/huggingface/).
HF_HOME=

# --- API server ---
# Required when running the API server (uv sync --extra api).
# Generate a random key, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# --- CLI client ---
# Required when using timesfm-meteo-client.
TIMESFM_API_URL=http://localhost:8000
TIMESFM_API_KEY=
